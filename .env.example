# Copy this file to .env and fill in real values. Never commit .env.
#
# The NASA Exoplanet Archive TAP API does not require an API key.
# This variable is only needed if you later integrate other NASA endpoints
# (e.g. https://api.nasa.gov/), which do require a key.
VITE_NASA_API_KEY=your_nasa_api_key_here

# Optional: override the default TAP base URL for the Exoplanet Archive.
VITE_EXOPLANET_TAP_URL=https://exoplanetarchive.ipac.caltech.edu/TAP/sync
